# Frontend
VITE_PATIENT_VOICE=true
# Browser calls this relative API route in production. Override only for advanced setups.
VITE_LLM_BASE_URL=/api/llm
VITE_MODEL_PATIENT=deepseek/deepseek-v4-pro
VITE_MODEL_INTERPRETER=deepseek/deepseek-v4-pro
VITE_MODEL_EXPERT=deepseek/deepseek-v4-pro
VITE_MODEL_EVALUATOR=deepseek/deepseek-v4-pro
VITE_MODEL_CASE_GENERATOR=deepseek/deepseek-v4-pro

# Serverless API secrets. Configure these in Vercel Project Settings, do not expose real keys in git.
LLM_BASE_URL=https://api.ominigate.ai
LLM_API_KEY=replace-with-your-llm-key
# Local dev only: Vite proxies /llm-proxy through this relay port.
LLM_RELAY_PORT=18788
# Optional fallback channel.
LLM_FALLBACK_BASE_URL=
LLM_FALLBACK_API_KEY=

PPIO_TTS_API_KEY=replace-with-your-tts-key
# Or use: PPIO_API_KEY=replace-with-your-ppio-key
PPIO_TTS_WATERMARK=false
